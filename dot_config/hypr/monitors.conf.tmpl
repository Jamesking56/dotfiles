# See https://wiki.hyprland.org/Configuring/Monitors/
# List current monitors and resolutions possible: hyprctl monitors
# Format: monitor = [port], resolution, position, scale

{{ if eq .chezmoi.hostname "James-Desktop" -}}
# James-Desktop: ultrawide + rotated 1080p secondary
env = GDK_SCALE,1
monitor=HDMI-A-1,1920x1080@119.88Hz,auto,1,transform,3
monitor=DP-1,3440x1440@99.98Hz,auto,1
{{ else if eq .chezmoi.hostname "James-Laptop" -}}
# James-Laptop: straight 1x setup
env = GDK_SCALE,1
monitor=,preferred,auto,1
{{ else -}}
# Unknown machine: fallback to auto
env = GDK_SCALE,1
monitor=,preferred,auto,1
{{ end -}}
